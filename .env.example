# 이 파일은 "예시"입니다. 실제 값이 든 .env 파일은 GitHub에 올리지 마세요.
# 아래 값들은 Vercel 프로젝트의 Environment Variables 에 등록합니다.

# 강사 비밀번호 (admin, 1234 같은 쉬운 값 금지)
TEACHER_PASSWORD=your_password_here

# Firebase 서비스 계정(.json) 값 — Firebase 6단계에서 받은 파일에서 복사
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# Realtime Database URL — Firebase 4단계에서 복사한 주소
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
